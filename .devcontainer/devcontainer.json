{
  "name": "vyoh.gg",
  "image": "mcr.microsoft.com/devcontainers/typescript-node:22",

  "features": {
    "ghcr.io/devcontainers/features/github-cli:1": {},
    "ghcr.io/devcontainers/features/docker-in-docker:2": {
      "moby": false
    },
    "ghcr.io/anthropics/devcontainer-features/claude-code:1": {}
  },

  "workspaceFolder": "/workspaces/vyoh.gg",
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspaces/vyoh.gg,type=bind,consistency=cached",

  "init": true,

  "mounts": [
    "source=${localEnv:HOME}/.claude,target=/home/node/.claude,type=bind,consistency=cached",
    "source=${localEnv:HOME}/.claude,target=${localEnv:HOME}/.claude,type=bind,consistency=cached"
  ],

  "containerEnv": {
    "TZ": "Europe/Brussels"
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "anthropic.claude-code",
        "biomejs.biome",
        "ms-azuretools.vscode-docker",
        "prisma.prisma",
        "bradlc.vscode-tailwindcss"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "biomejs.biome",
        "editor.codeActionsOnSave": {
          "source.fixAll.biome": "explicit"
        },
        "biome.lsp.bin": "${workspaceFolder}/node_modules/.bin/biome"
      }
    }
  },

  "forwardPorts": [2009, 2010, 5432],

  "portsAttributes": {
    "2009": { "label": "Web (Vite)" },
    "2010": { "label": "API (NestJS)" },
    "5432": { "label": "Postgres" }
  },

  "postCreateCommand": "sudo apt-get update -qq && sudo apt-get install -y --no-install-recommends ugrep bfs jq && npm install -g typescript-language-server typescript && sudo corepack enable && CI=true pnpm bootstrap && ~/.claude/bootstrap.sh plugins && ~/.claude/bootstrap.sh tokf",

  "remoteUser": "node"
}
