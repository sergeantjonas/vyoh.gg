{
  "name": "vyoh.gg",
  "image": "mcr.microsoft.com/devcontainers/typescript-node:22",

  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "22",
      "nvmVersion": "none"
    },
    "ghcr.io/devcontainers/features/github-cli:1": {},
    "ghcr.io/devcontainers/features/docker-in-docker:2": {
      "moby": false
    }
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "biomejs.biome",
        "ms-azuretools.vscode-docker",
        "prisma.prisma",
        "bradlc.vscode-tailwindcss",
        "ms-vscode.vscode-typescript-next",
        "antfu.unocss"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "biomejs.biome",
        "editor.codeActionsOnSave": {
          "source.fixAll.biome": "explicit"        
        },
        "biome.lsp.bin": "${workspaceFolder}/node_modules/.bin/biome"
      }
    }
  },

  "forwardPorts": [2009, 2010, 5432],

  "portsAttributes": {
    "2009": { "label": "Web (Vite)" },
    "2010": { "label": "API (NestJS)" },
    "5432": { "label": "Postgres" }
  },

  "postCreateCommand": "npm install -g pnpm @anthropic-ai/claude-code && git -c http.version=HTTP/1.1 clone https://github.com/sergeantjonas/dotfiles.git ~/dotfiles && ~/dotfiles/install.sh && pnpm bootstrap",

  "remoteUser": "node"
}