{
  "name": "vyoh.gg",
  "private": true,
  "packageManager": "pnpm@11.1.1+sha512.d1fdf5f73c617b64fa1a56a81c3c8dfe0e966e33a6010aa256b517ae77be21d93e05affc0de1a83b0e4f29d569f68b446ae8f068cd7247c0bb3df0fb4d7bdf9a",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "bootstrap": "bash scripts/setup.sh",
    "dev": "docker compose up -d --wait postgres && concurrently --names web,api --prefix-colors cyan,magenta \"pnpm --filter @vyoh/web dev\" \"pnpm --filter @vyoh/api start:dev\"",
    "db:up": "docker compose up -d --wait postgres",
    "db:down": "docker compose down",
    "reset": "bash scripts/reset.sh",
    "refresh:lol-assets": "tsx scripts/refresh-lol-assets.mts",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "ci:check": "biome ci .",
    "typecheck": "pnpm -r typecheck",
    "check:cc": "biome ci . --colors=off --max-diagnostics=30",
    "check:fix:cc": "biome check --write . --colors=off --max-diagnostics=30",
    "typecheck:cc": "pnpm -r typecheck 2>&1 | head -300",
    "test:cc": "pnpm -r test 2>&1 | head -400",
    "verify:cc": "pnpm run check:cc && pnpm run typecheck:cc && pnpm run test:cc"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "blurhash": "^2.0.5",
    "concurrently": "^9.1.0",
    "sharp": "^0.34.5",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
