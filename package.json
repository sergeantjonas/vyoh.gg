{
  "name": "vyoh.gg",
  "private": true,
  "packageManager": "pnpm@10.12.1",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "bootstrap": "bash scripts/setup.sh",
    "dev": "docker compose up -d --wait postgres && concurrently --names web,api --prefix-colors cyan,magenta \"pnpm --filter @vyoh/web dev\" \"pnpm --filter @vyoh/api start:dev\"",
    "db:up": "docker compose up -d --wait postgres",
    "db:down": "docker compose down",
    "reset": "bash scripts/reset.sh",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "ci:check": "biome ci .",
    "typecheck": "pnpm -r typecheck",
    "check:cc": "biome ci .",
    "check:fix:cc": "biome check --write .",
    "typecheck:cc": "pnpm -r typecheck",
    "test:cc": "pnpm -r test",
    "verify:cc": "pnpm run check:cc && pnpm run typecheck:cc && pnpm run test:cc"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "concurrently": "^9.1.0",
    "typescript": "^6.0.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["sharp"]
  }
}
