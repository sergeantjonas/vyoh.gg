    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@resvg/resvg-js": "^2.6.2",
    "@vyoh/shared": "workspace:*",
    "bottleneck": "^2.19.5",
    "dotenv": "^17.4.2",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "satori": "^0.26.0",
    "steam-user": "^5.2.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@swc/cli": "^0.5.0",
    "@swc/core": "^1.10.7",
    "@types/express": "^5.0.0",
    "@types/node": "^24.0.0",
    "@types/pg": "^8.20.0",
    "prisma": "^7.8.0",
    "tsx": "^4.21.0",
    "unplugin-swc": "^1.5.1",
    "vitest": "^4.1.5"
  }
