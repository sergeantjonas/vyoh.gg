DATABASE_URL=postgresql://vyoh:vyoh@localhost:5432/vyoh

# Get a development key (24h-expiring) from https://developer.riotgames.com/
RIOT_API_KEY=RGAPI-XXXXXXXX-XXXX-XXXX-XXXX-XXXXXXXXXXXX

# Get a Web API key (non-expiring) from https://steamcommunity.com/dev/apikey
# Owner SteamID64 is hardcoded in apps/api/src/steam/steam.config.ts.
STEAM_API_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Optional overrides (all have safe defaults)
PORT=2010
CUTOFF_DAYS=90
MATCH_SYNC_ENABLED=true
LOL_PREWARM=0
STEAM_PREWARM=0
