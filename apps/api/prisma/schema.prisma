generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Summoner {
  puuid     String   @id
  gameName  String
  tagLine   String
  region    String
  fetchedAt DateTime @default(now())

  matches Match[]

  @@unique([gameName, tagLine, region])
}

model Match {
  matchId     String
  puuid       String
  queueType   String
  champion    String
  kills       Int
  deaths      Int
  assists     Int
  win         Boolean
  durationSec Int
  playedAt    DateTime

  summoner Summoner @relation(fields: [puuid], references: [puuid])

  @@id([matchId, puuid])
  @@index([puuid, playedAt])
}
