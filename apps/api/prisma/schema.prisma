generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Summoner {
  puuid            String    @id
  gameName         String
  tagLine          String
  region           String
  profileIconId    Int?
  summonerLevel    Int?
  fetchedAt        DateTime  @default(now())
  historicalDoneAt DateTime?

  matches       Match[]
  rankSnapshots RankSnapshot[]

  @@unique([gameName, tagLine, region])
}

model RankSnapshot {
  id           Int      @id @default(autoincrement())
  puuid        String
  queueId      String
  tier         String
  rank         String
  leaguePoints Int
  wins         Int?
  losses       Int?
  hotStreak    Boolean?
  capturedAt   DateTime @default(now())

  summoner Summoner @relation(fields: [puuid], references: [puuid])

  @@index([puuid, queueId, capturedAt])
}

model MatchDetailCache {
  matchId  String   @id
  detail   Json
  cachedAt DateTime @default(now())
}

model MatchTimelineCache {
  matchId  String   @id
  timeline Json
  cachedAt DateTime @default(now())
}

model SteamOwnedGame {
  appid       Int       @id
  name        String
  firstSeenAt DateTime  @default(now())
  lastSeenAt  DateTime  @default(now())
  removedAt   DateTime?

  snapshots       SteamPlaytimeSnapshot[]
  enrichment      SteamGameEnrichment?
  achievements    SteamGameAchievement[]
  achievementMeta SteamGameAchievementMeta?
}

// Per-app metadata fetched from IStoreBrowseService/GetItems. One row per
// owned appid (the enrichment poller is keyed off SteamOwnedGame). Assets are
// stored as path fragments (Steam's "${FILENAME}" substitutions, hash-prefixed
// + asset filename in one string, e.g. "1eebc7e0…e4e3/library_capsule.jpg")
// plus a single `assetUrlFormat` template + `assetTimestamp` cache-buster.
// Caller composes the full URL by substituting the path into the format. A
// change in `assetTimestamp` indicates the publisher refreshed art.
//
// `appType` is Steam's StoreItemType enum int: 0 = Game, 6 = Application /
// Software (Wallpaper Engine, 3DMark, OBS-class tools), other values for DLC /
// bundles / demos. Frontend maps to a label. `tagIds` carries the appid's
// community-tag ids ordered by weight desc (top-N stored, full list is huge);
// stand-in for Steam's "genre" metadata which IStoreBrowseService doesn't
// expose directly. `featureCategoryIds` is the small int list under
// `categories.feature_categoryids` for feature-flag filters (single-player,
// achievements, cloud save, etc.). `logoPath` is the per-app SHA1 hash for
// the wordmark/library_logo asset, sourced from PICS' `common.library_assets
// (_full).library_logo` — IStoreBrowseService omits this field. Frontend
// composes `…/store_item_assets/steam/apps/{appid}/{logoPath}/logo.png`.
// Null when PICS didn't return a logo entry (older titles where the
// unhashed legacy mirror is the only path); frontend falls back to that.
model SteamGameEnrichment {
  appid                Int       @id
  assetUrlFormat       String?
  assetTimestamp       BigInt?
  libraryCapsulePath   String?
  libraryCapsule2xPath String?
  libraryHeroPath      String?
  libraryHero2xPath    String?
  headerPath           String?
  heroCapsulePath      String?
  logoPath             String?
  appType              Int?
  releaseDate          DateTime? @db.Date
  isFree               Boolean?
  tagIds               Int[]
  featureCategoryIds   Int[]
  enrichedAt           DateTime  @default(now())
  // Screenshots from store.steampowered.com/api/appdetails. Fetched lazily on
  // tile-hover rather than by the monthly enrichment cron — appdetails caps
  // at ~200 req / 5 min per IP, and only a handful of the 167+ owned games
  // are ever hovered. JSON shape: `[{ thumbUrl, fullUrl }]`. Defaults to
  // `[]` so a missing fetch + an empty upstream both serialize the same;
  // `screenshotsFetchedAt` is the source of truth for "we've tried" — a
  // null timestamp means never fetched.
  screenshots          Json      @default("[]")
  screenshotsFetchedAt DateTime?

  game SteamOwnedGame @relation(fields: [appid], references: [appid])
}

// Per-game achievement schema from ISteamUserStats/GetSchemaForGame. Refreshed
// monthly by SteamAchievementSchemaPoller. Games with no achievements (CS2,
// demos, dedicated-launcher entries) leave no rows here — the meta sidecar's
// `achievementCount` records the empty-stats check so the poller doesn't
// thrash refetching empty schemas.
//
// `hidden = true` is Steam's spoiler flag: `displayName` + `description` render
// as `???` placeholders while the achievement is locked. Once the owner
// unlocks it the full text reveals (matches Steam's own client). Icon URLs
// are absolute community-CDN paths returned directly by the API.
model SteamGameAchievement {
  appid           Int
  apiName         String
  displayName     String
  description     String
  iconUrl         String
  iconGrayUrl     String
  hidden          Boolean  @default(false)
  schemaFetchedAt DateTime @default(now())

  game   SteamOwnedGame                @relation(fields: [appid], references: [appid])
  unlock SteamPlayerUnlock?
  rarity SteamAchievementGlobalRarity?

  @@id([appid, apiName])
}

// Per-owner unlock events from ISteamUserStats/GetPlayerAchievements. Each
// achievement can only be unlocked once, so `(appid, apiName)` is the natural
// PK. `unlockedAt` is the historical Steam `unlocktime` (every poll backfills
// real history retroactively — the "Day 1 looks like year N" property called
// out in the achievement family brainstorm). `recordedAt` is local — separates
// game-timeline data from observability.
model SteamPlayerUnlock {
  appid      Int
  apiName    String
  unlockedAt DateTime
  recordedAt DateTime @default(now())

  achievement SteamGameAchievement @relation(fields: [appid, apiName], references: [appid, apiName])

  @@id([appid, apiName])
  @@index([unlockedAt])
}

// Global unlock percentage per achievement from
// GetGlobalAchievementPercentagesForApp. Steam returns 0..100 as a float.
// Refreshed weekly. Drives the rarity badge on the per-game panel + the
// "rare unlock" annotation on the completion verdict card. Endpoint is
// unauthenticated but routed through the limiter for consistency.
model SteamAchievementGlobalRarity {
  appid    Int
  apiName  String
  percent  Float
  polledAt DateTime @default(now())

  achievement SteamGameAchievement @relation(fields: [appid, apiName], references: [appid, apiName])

  @@id([appid, apiName])
}

// Sidecar bookkeeping for the three achievement pollers (monthly schema,
// daily unlocks, weekly rarity). Separated from SteamGameEnrichment because
// the cadences and failure modes are independent — a schema-fetch failure
// shouldn't block enrichment, and vice versa.
//
// `achievementCount` is the only persisted result: null = unknown, 0 =
// checked, no achievements (skip future fetches), N > 0 = N achievements
// known. Lets the schema poller short-circuit games like CS2 / demos
// without re-fetching every month.
model SteamGameAchievementMeta {
  appid                Int       @id
  achievementCount     Int?
  lastSchemaCheckedAt  DateTime?
  lastUnlocksCheckedAt DateTime?
  lastRarityCheckedAt  DateTime?

  game SteamOwnedGame @relation(fields: [appid], references: [appid])
}

// Singleton-ish state for the live owner — refreshed every 2 min by
// SteamPlayerStatePoller (1 call to GetPlayerSummaries). Drives the
// "Now playing" chip and (in later S6 chunks) acts as the event source
// for persisted play sessions + event-driven achievement refresh.
//
// `currentAppid` mirrors GetPlayerSummaries' `gameid` field (null when
// not in-game). `currentGameName` is the `gameextrainfo` snapshot kept
// inline so the chip can render the human label without a second lookup
// against owned-games — and so it still renders for non-owned titles
// (friend's shared library, family-share, etc.). `personaState` stores
// the already-normalized string union from SteamSummary so the read
// endpoint doesn't have to re-map on every request.
model SteamPlayerState {
  steamId           String   @id
  personaName       String
  avatarUrl         String
  personaState      String
  profileVisibility Int
  currentAppid      Int?
  currentGameName   String?
  lastPolledAt      DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

// One row per play session — opened when the owner enters a game, closed
// when they leave it (or transition to a different game). Driven by the
// every-2-min player-state poller diffing `currentAppid` transitions:
//   null → X   opens a session for X
//   X → null   closes the open session for X
//   X → Y      closes X, opens Y
//
// `endedAt` is set to the *previous* tick's `lastPolledAt` when the
// transition fires — that's the last moment we observed the owner still in
// the game, and it preserves a sensible close timestamp across poller
// downtime (a crash window of N hours closes at the pre-crash lastPolledAt,
// not the post-reboot wall clock). For orphan sessions with no matching
// previous state, falls back to now().
//
// `gameNameSnapshot` captures `gameextrainfo` at open time so historical
// rows stay legible after a publisher rebrand. `appid` is intentionally
// *not* an FK to SteamOwnedGame — family-share / non-owned titles still
// produce sessions.
model SteamPlaySession {
  id               String    @id @default(cuid())
  appid            Int
  gameNameSnapshot String
  startedAt        DateTime  @default(now())
  endedAt          DateTime?

  @@index([endedAt])
  @@index([appid, startedAt])
}

// Steam's global community-tag catalog (id → name). Pulled monthly from
// IStoreService/GetTagList. Resolves the `tagIds` carried on
// SteamGameEnrichment into human labels for the library filter popover.
// Decoupled from owned games on purpose — the catalog is global and Steam
// occasionally adds tags, so the cron is a separate concern from the per-app
// enrichment refresh. `updatedAt` carries the row's last touch (insert or
// rename); the `lastSyncedAt` API field uses the table's max of this column.
model SteamTag {
  id        Int      @id
  name      String
  updatedAt DateTime @default(now()) @updatedAt
}

model SteamPlaytimeSnapshot {
  appid                  Int
  snapshotDate           DateTime @db.Date
  playtimeForeverMinutes Int
  playtime2WeeksMinutes  Int?
  playtimeWindowsMinutes Int?
  playtimeMacMinutes     Int?
  playtimeLinuxMinutes   Int?
  playtimeDeckMinutes    Int?

  game SteamOwnedGame @relation(fields: [appid], references: [appid])

  @@id([appid, snapshotDate])
  @@index([snapshotDate])
}

model Match {
  matchId      String
  puuid        String
  queueType    String
  champion     String
  kills        Int
  deaths       Int
  assists      Int
  win          Boolean
  durationSec  Int
  playedAt     DateTime
  items        Int[]
  laneOpponent Json?
  teamPosition String   @default("")
  gameVersion  String   @default("")
  visionScore  Int      @default(0)
  damageShare  Float    @default(0)
  firstBloodKill Boolean @default(false)
  csAt10       Int      @default(0)
  csAt15       Int      @default(0)
  goldAt10     Int      @default(0)
  goldAt15     Int      @default(0)
  teamGoldDiffAt15 Int  @default(0)
  deathTimings Int[]    @default([])
  deathXs      Int[]    @default([])
  deathYs      Int[]    @default([])
  killTimings  Int[]    @default([])
  killXs       Int[]    @default([])
  killYs       Int[]    @default([])
  remake       Boolean  @default(false)
  snapshotTier       String?
  snapshotRank       String?
  snapshotLp         Int?
  snapshotTierBefore String?
  snapshotRankBefore String?
  snapshotLpBefore   Int?

  summoner Summoner @relation(fields: [puuid], references: [puuid])

  @@id([matchId, puuid])
  @@index([puuid, playedAt])
}
