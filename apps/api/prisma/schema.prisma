generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Summoner {
  puuid            String    @id
  gameName         String
  tagLine          String
  region           String
  profileIconId    Int?
  summonerLevel    Int?
  fetchedAt        DateTime  @default(now())
  historicalDoneAt DateTime?

  matches       Match[]
  rankSnapshots RankSnapshot[]

  @@unique([gameName, tagLine, region])
}

model RankSnapshot {
  id           Int      @id @default(autoincrement())
  puuid        String
  queueId      String
  tier         String
  rank         String
  leaguePoints Int
  wins         Int?
  losses       Int?
  hotStreak    Boolean?
  capturedAt   DateTime @default(now())

  summoner Summoner @relation(fields: [puuid], references: [puuid])

  @@index([puuid, queueId, capturedAt])
}

model MatchDetailCache {
  matchId  String   @id
  detail   Json
  cachedAt DateTime @default(now())
}

model Match {
  matchId      String
  puuid        String
  queueType    String
  champion     String
  kills        Int
  deaths       Int
  assists      Int
  win          Boolean
  durationSec  Int
  playedAt     DateTime
  items        Int[]
  laneOpponent Json?
  remake       Boolean  @default(false)
  snapshotTier String?
  snapshotRank String?
  snapshotLp   Int?

  summoner Summoner @relation(fields: [puuid], references: [puuid])

  @@id([matchId, puuid])
  @@index([puuid, playedAt])
}
