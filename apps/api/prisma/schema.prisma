generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Summoner {
  puuid            String    @id
  gameName         String
  tagLine          String
  region           String
  profileIconId    Int?
  summonerLevel    Int?
  fetchedAt        DateTime  @default(now())
  historicalDoneAt DateTime?

  matches       Match[]
  rankSnapshots RankSnapshot[]

  @@unique([gameName, tagLine, region])
}

model RankSnapshot {
  id           Int      @id @default(autoincrement())
  puuid        String
  queueId      String
  tier         String
  rank         String
  leaguePoints Int
  wins         Int?
  losses       Int?
  hotStreak    Boolean?
  capturedAt   DateTime @default(now())

  summoner Summoner @relation(fields: [puuid], references: [puuid])

  @@index([puuid, queueId, capturedAt])
}

model MatchDetailCache {
  matchId  String   @id
  detail   Json
  cachedAt DateTime @default(now())
}

model MatchTimelineCache {
  matchId  String   @id
  timeline Json
  cachedAt DateTime @default(now())
}

model SteamOwnedGame {
  appid       Int       @id
  name        String
  firstSeenAt DateTime  @default(now())
  lastSeenAt  DateTime  @default(now())
  removedAt   DateTime?

  snapshots  SteamPlaytimeSnapshot[]
  enrichment SteamGameEnrichment?
}

// Per-app metadata fetched from IStoreBrowseService/GetItems. One row per
// owned appid (the enrichment poller is keyed off SteamOwnedGame). Assets are
// stored as path fragments (Steam's "${FILENAME}" substitutions, hash-prefixed
// + asset filename in one string, e.g. "1eebc7e0…e4e3/library_capsule.jpg")
// plus a single `assetUrlFormat` template + `assetTimestamp` cache-buster.
// Caller composes the full URL by substituting the path into the format. A
// change in `assetTimestamp` indicates the publisher refreshed art.
//
// `appType` is Steam's StoreItemType enum int: 0 = Game, 6 = Application /
// Software (Wallpaper Engine, 3DMark, OBS-class tools), other values for DLC /
// bundles / demos. Frontend maps to a label. `tagIds` carries the appid's
// community-tag ids ordered by weight desc (top-N stored, full list is huge);
// stand-in for Steam's "genre" metadata which IStoreBrowseService doesn't
// expose directly. `featureCategoryIds` is the small int list under
// `categories.feature_categoryids` for feature-flag filters (single-player,
// achievements, cloud save, etc.). Logo asset is not exposed by
// IStoreBrowseService — the unhashed `logo.png` path stays in use.
model SteamGameEnrichment {
  appid                Int       @id
  assetUrlFormat       String?
  assetTimestamp       BigInt?
  libraryCapsulePath   String?
  libraryCapsule2xPath String?
  libraryHeroPath      String?
  libraryHero2xPath    String?
  headerPath           String?
  heroCapsulePath      String?
  appType              Int?
  releaseDate          DateTime? @db.Date
  isFree               Boolean?
  tagIds               Int[]
  featureCategoryIds   Int[]
  enrichedAt           DateTime  @default(now())

  game SteamOwnedGame @relation(fields: [appid], references: [appid])
}

// Steam's global community-tag catalog (id → name). Pulled monthly from
// IStoreService/GetTagList. Resolves the `tagIds` carried on
// SteamGameEnrichment into human labels for the library filter popover.
// Decoupled from owned games on purpose — the catalog is global and Steam
// occasionally adds tags, so the cron is a separate concern from the per-app
// enrichment refresh. `updatedAt` carries the row's last touch (insert or
// rename); the `lastSyncedAt` API field uses the table's max of this column.
model SteamTag {
  id        Int      @id
  name      String
  updatedAt DateTime @default(now()) @updatedAt
}

model SteamPlaytimeSnapshot {
  appid                  Int
  snapshotDate           DateTime @db.Date
  playtimeForeverMinutes Int
  playtime2WeeksMinutes  Int?
  playtimeWindowsMinutes Int?
  playtimeMacMinutes     Int?
  playtimeLinuxMinutes   Int?
  playtimeDeckMinutes    Int?

  game SteamOwnedGame @relation(fields: [appid], references: [appid])

  @@id([appid, snapshotDate])
  @@index([snapshotDate])
}

model Match {
  matchId      String
  puuid        String
  queueType    String
  champion     String
  kills        Int
  deaths       Int
  assists      Int
  win          Boolean
  durationSec  Int
  playedAt     DateTime
  items        Int[]
  laneOpponent Json?
  teamPosition String   @default("")
  gameVersion  String   @default("")
  visionScore  Int      @default(0)
  damageShare  Float    @default(0)
  firstBloodKill Boolean @default(false)
  csAt10       Int      @default(0)
  csAt15       Int      @default(0)
  goldAt10     Int      @default(0)
  goldAt15     Int      @default(0)
  teamGoldDiffAt15 Int  @default(0)
  deathTimings Int[]    @default([])
  deathXs      Int[]    @default([])
  deathYs      Int[]    @default([])
  killTimings  Int[]    @default([])
  killXs       Int[]    @default([])
  killYs       Int[]    @default([])
  remake       Boolean  @default(false)
  snapshotTier       String?
  snapshotRank       String?
  snapshotLp         Int?
  snapshotTierBefore String?
  snapshotRankBefore String?
  snapshotLpBefore   Int?

  summoner Summoner @relation(fields: [puuid], references: [puuid])

  @@id([matchId, puuid])
  @@index([puuid, playedAt])
}
